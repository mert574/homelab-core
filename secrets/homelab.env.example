# Plaintext template. Real values never get committed in plaintext.
#
# Workflow:
#   cp homelab.env.example homelab.env     # fill in real values (gitignored)
#   sops --encrypt homelab.env > homelab.enc.env   # commit only homelab.enc.env
#   rm homelab.env                          # don't leave plaintext lying around
#
# At bootstrap, the script decrypts homelab.enc.env and sources it, so these
# become environment variables for the pipeline. Names starting with TF_VAR_ are
# read directly by OpenTofu (TF_VAR_pve_api_token -> var.pve_api_token), so no
# plaintext terraform.tfvars is needed.

# --- git access for private repos ---
# Used to clone private repos during provisioning and as Argo CD repo creds, so
# it can sync private app/manifest repos. Use a read-only, fine-grained PAT
# scoped to just the repos you need, with an expiry. Over HTTPS the token is the
# password; x-access-token works as the username for GitHub.
GIT_HTTP_USERNAME=x-access-token
GIT_HTTP_TOKEN=github_pat_REPLACE

# --- Layer 2 (OpenTofu) ---
TF_VAR_pve_api_token=tofu@pve!homelab=REPLACE-WITH-REAL-TOKEN
TF_VAR_ct_root_password=REPLACE
TF_VAR_ssh_public_key=ssh-ed25519 AAAA...REPLACE you@laptop

# --- Layer 3 (injected into the cluster as secrets) ---
# cloudflared creds are a JSON file (secrets/cloudflared.creds.enc), not a token.
POSTGRES_PASSWORD=REPLACE

# --- Garage object storage (rpc + admin tokens; generate random) ---
# openssl rand -hex 32
GARAGE_RPC_SECRET=REPLACE
GARAGE_ADMIN_TOKEN=REPLACE

# --- GitHub Actions runner (ARC in the cluster) ---
# PAT with repo scope; ARC's listener uses it to register ephemeral runners
GITHUB_RUNNER_TOKEN=REPLACE

# --- host Wi-Fi fallback uplink ---
# Wired link stays primary; Wi-Fi only carries the host, not the guests.
WIFI_SSID="REPLACE"
WIFI_PSK=REPLACE

# --- Pulse (cluster/apps/pulse; created into the cluster by create-secrets.sh) ---
# DB role password, also set on the postgres LXC via sops-nix.
PULSE_DB_PASSWORD=REPLACE
# base64 of 32 random bytes (AES-256 key)
PULSE_SECRET_KEY=REPLACE
# RS256 PEM for JWT signing (api only). Multiline; keep as one quoted value or
# use the file path mount (see cluster/apps/pulse/README.md).
PULSE_JWT_PRIVATE_KEY_PEM=REPLACE
PULSE_GOOGLE_CLIENT_ID=REPLACE
PULSE_GOOGLE_CLIENT_SECRET=REPLACE
PULSE_GITHUB_CLIENT_ID=REPLACE
PULSE_GITHUB_CLIENT_SECRET=REPLACE
PULSE_SMTP_PASSWORD=REPLACE
PULSE_BILLING_WEBHOOK_SECRET=REPLACE

# --- digarr DB role (on the postgres LXC); digarr's own env is secrets/digarr.env.enc ---
DIGARR_DB_PASSWORD=REPLACE
